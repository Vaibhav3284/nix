#!/bin/bash

SAVE_DIR="/home/bored/Videos/Recordings"
mkdir -p "$SAVE_DIR"
FILENAME="$SAVE_DIR/recording_$(date +'%Y-%m-%d_%H-%M-%S').mp4"

# 1. Kill any existing instances immediately to prevent the double-toggle loop
if pgrep -x "wf-recorder" > /dev/null; then
    pkill -SIGINT -x "wf-recorder"
    notify-send "Screen Recorder" "Recording stopped and saved." -i video-x-generic
    exit 0
fi

# 2. Start the recording
notify-send "Screen Recorder" "Recording started..." -i video-x-generic

# Using Pulse/Pipewire default source explicitly helps prevent immediate audio backend crashes
wf-recorder --audio=default_input -f "$FILENAME" > /dev/null 2>&1 &
