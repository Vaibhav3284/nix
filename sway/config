### Variables
## Global Appearance Deets
# theme (as well as its include :tired:)
include /home/mb/.config/sway/current.theme

# font
set $font Input Sans Narrow 15

# Popup colors
set $bemenu_opts -bl10 --fn '$font' --tb '$ac' --tf '$bg' --nb '$bg' --nf '$fg' --fb '$bg' --ff '$ac' --hb '$bg' --hf '$ac' --ab '$bg' --af '$fg' --cb '$bg' --cf '$fg'
set $swaynag_cols --background $rur --button-background $rur --button-border-size 0 --text $rbg --button-text $rbg --border-bottom $rfg

# color boilerplate
set $fg #$rfg
set $bg #$rbg
set $ac #$rac
set $mg #$rmg
set $ur #$rur
set $bc #$rbc

## General knobs
set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term foot
set $ed "emacsclient -c"
set $menu bemenu-run $bemenu_opts 

### Config Begins here
## appearance
client.focused $bc $bc $bg $bc
client.focused_inactive $bg $bg $fg $bg
client.unfocused $bg $bg $fg $bg
client.urgent $ur $ur $bg

default_border pixel 1
font pango:$font

output * bg $wall

## Startup Programs
exec wl-paste -t text --watch clipman store
exec wl-paste -p -t text --watch clipman store -P --histpath="~/.local/share/clipman-primary.json"

set $xdg_vars DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP
exec dbus-update-activation-environment --all
exec hash dbus-update-activation-environment 2>/dev/null && dbus-update-activation-environment $xdg_vars
exec_always swaymsg "setenv XDG_CURRENT_DESKTOP sway"
exec pipewire
exec pipewire-pulse
exec musicpd
exec emacs --daemon

## Keybinds
bindsym $mod+Return exec $term
bindsym $mod+e exec $ed
bindsym $mod+o exec clipman pick -t bemenu -T"$bemenu_opts"
bindsym $mod+q kill
bindsym $mod+s exec "~/desktoputil.sh shot"
bindsym $mod+Shift+s exec "~/desktoputil.sh shot select"
bindsym $mod+p exec $menu

bindsym $mod+n layout toggle split
floating_modifier $mod normal

bindsym $mod+r exec "~/desktoputil.sh reconf"
bindsym $mod+t mode "switch-theme"
mode "switch-theme" {
     bindsym k mode "theme-kanagawa"
     bindsym g mode "theme-gruvbox"
     bindsym s mode "theme-solarized"
}
mode "theme-kanagawa" {
     bindsym d exec "~/desktoputil.sh change-theme kanagawa-dragon"
     bindsym w exec "~/desktoputil.sh change-theme kanagawa-wave"
}
mode "theme-gruvbox" {
     bindsym d exec "~/desktoputil.sh change-theme gruvbox-dark"
     bindsym l exec "~/desktoputil.sh change-theme gruvbox-light"
}
mode "theme-solarized" {
     bindsym d exec "~/desktoputil.sh change-theme solarized-dark"
     bindsym l exec "~/desktoputil.sh change-theme solarized-light"
}
bindsym $mod+Shift+q exec swaynag -f $font -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -B 'Yes, exit sway' 'swaymsg exit' $swaynag_cols
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

bindsym $mod+f fullscreen
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

bindsym --locked $mod+d exec "$HOME/desktoputil.sh vol dec"
bindsym --locked $mod+c exec "$HOME/desktoputil.sh vol inc"
bindsym --locked $mod+a exec "$HOME/desktoputil.sh bright dec"
bindsym --locked $mod+z exec "$HOME/desktoputil.sh bright inc"
bindsym Print exec grim

bar {
    position top
    status_command ~/desktoputil.sh bar
    colors {
    	   statusline $fg
    	   background $bg
    	   inactive_workspace $bg $bg $fg
    	   focused_workspace $ac $ac $bg
    }
}